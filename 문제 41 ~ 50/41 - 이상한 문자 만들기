// 문자열 s는 한 개 이상의 단어로 구성되어 있습니다.
// 각 단어는 하나 이상의 공백문자로 구분되어 있습니다.
// 각 단어의 짝수번째 알파벳은 대문자로, 홀수번째 알파벳은 소문자로 바꾼 문자열을 리턴하는 함수, solution을 완성하세요.

#include <string>
#include <vector>

using namespace std;

// 해당 문제의 핵심은 공백은 기준으로 짝수와 홀수로 나눈다는 것이다.
string solution(string s) {
    string answer = "";
    int index = 0; // 공백을 기준으로 재시작하기 위한 변수

    for(int i = 0; i < s.size(); i++){
        // 공백은 찾으면 다음 문자열부터 다시 짝, 홀수를 찾기 위한 초기화.
        // 인덱스를 -1로 초기화해서 if문이 끝나고 index++를 해서 다음 문자열부터 0으로 카운트.
        if(s[i] == ' '){
            index = -1;
        }
        else{
            if(index % 2 == 0){ // 인덱스를 기준으로 짝수일 경우
                s[i] = toupper(s[i]); // 대문자로 변환
            }
            else{ // 인덱스를 기준으로 홀수일 경우
                s[i] = tolower(s[i]); // 소문자로 변환
            }
        }
        index++;
    }

    answer = s;

    return answer;
}
