// 숫자의 일부 자릿수가 영단어로 바뀌어졌거나, 혹은 바뀌지 않고 그대로인 문자열 s가 매개변수로 주어집니다.
// s가 의미하는 원래 숫자를 return 하도록 solution 함수를 완성해주세요.

#include <string>
#include <vector>

using namespace std;

int solution(string s) {
    string num[10] = {
        "zero", "one", "two", "three", "four",
        "five", "six", "seven", "eight", "nine"
    };

    for(int i = 0; i < 10; i++){
        size_t pos;
        // 해당 숫자의 영어 단어가 문자열 s에 없을 때까지 반복하여 숫자로 치환
        while((pos = s.find(num[i])) != string::npos){
            s.replace(pos, num[i].length(), to_string(i));
        }
    }

    return stoi(s);
}
