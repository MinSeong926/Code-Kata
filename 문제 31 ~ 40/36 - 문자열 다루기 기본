// 문자열 s의 길이가 4 혹은 6이고, 숫자로만 구성돼있는지 확인해주는 함수, solution을 완성하세요.
// 예를 들어 s가 "a234"이면 False를 리턴하고 "1234"라면 True를 리턴하면 됩니다.

#include <string>
#include <vector>

using namespace std;

bool solution(string s) {
    bool answer = true;
    
    if(s.size() != 4 && s.size() != 6){
        return false;
    }
    
    for(int i = 0; i < s.size(); i++){
        if(s[i] < '0' || s[i] > '9'){
            return false;
        }
    }
    
    return answer;
}
