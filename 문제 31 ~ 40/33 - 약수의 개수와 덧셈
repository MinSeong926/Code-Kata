// 두 정수 left와 right가 매개변수로 주어집니다. 
// left부터 right까지의 모든 수들 중에서, 약수의 개수가 짝수인 수는 더하고,
// 약수의 개수가 홀수인 수는 뺀 수를 return 하도록 solution 함수를 완성해주세요.

#include <string>
#include <vector>

using namespace std;

int solution(int left, int right) {
    int answer = 0;
    int count = 0; // 약수의 개수 측정

    for(left; left <= right; left++) {
        count = 0;

        for(int i=1; i<=left; i++) { // left부터 right까지 모든 수의 약수를 구하기
            if(left % i ==0) { // 약수면 카운트
                count ++;
            }
        }

        if(count % 2 == 0) { // 약수의 개수가 짝이면 +, 홀수면 -
            answer += left;
        } else {
            answer -= left;
        }
    }

    return answer;
}
