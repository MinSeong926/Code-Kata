// 정수 num1, num2가 매개변수로 주어질 때, num1을 num2로 나눈 몫을 return 하도록 solution 함수를 완성해주세요.

#include <string> // 문자열 사용
#include <vector> // 벡터 객체 사용
#include <iostream> // 입출력 사용

using namespace std;

// num1, num2를 나누는 함수
int solution(int num1, int num2) {
    int answer = num1 / num2;
    return answer; // answer 값 리턴
}

int main(){
    int num1, num2;

    cin >> num1 >> num2; // num1, num2 입력

    cout << solution(num1, num2) << endl; // 바로 출력하게끔 solution 입력

    return 0;
}
