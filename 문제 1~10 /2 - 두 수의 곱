// 두 수의 곱 구하기
// 정수 num1, num2가 매개변수 주어집니다. num1과 num2를 곱한 값을 return 하도록 solution 함수를 완성해주세요.

// 입출력 예
// num1이 3, num2가 4이므로 3 * 4 = 12를 return합니다.

#include <string>
#include <vector>
#include <iostream>

using namespace std;

int solution(int num1, int num2) {
    int answer = num1 * num2;
    return answer;
}

int main(){
    int num1, num2;

    cout << "num1 입력 : ";
    cin >> num1;

    cout << "num2 입력 : ";
    cin >> num2;

    cout << "result" << solution(num1, num2) << endl;

    return 0;
}
