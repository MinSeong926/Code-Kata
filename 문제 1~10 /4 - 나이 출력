// 머쓱이는 선생님이 몇 년도에 태어났는지 궁금해졌습니다. 2022년 기준 선생님의 나이 age가 주어질 때, 선생님의 출생 연도를 return 하는 solution 함수를 완성해주세요

#include <string>
#include <vector>
#include <iostream>

using namespace std;

int solution(int age) {
    int answer = 2022 - (age - 1); // 대한민국은 기본 1살부터 시작하니 -1을 해준다.
    return answer;
}

int main(){
    int age;

    while(1){
        cin >> age;
        if(age < 0 || age >= 120){
            cout << "값이 너무 큽니다." << endl;
            cout << "다시 입력하세요." << endl;
        }
        else if(age > 0 && age <= 120){
            break;
        }
    }

    cout << solution(age) << endl;

    return 0;
}
