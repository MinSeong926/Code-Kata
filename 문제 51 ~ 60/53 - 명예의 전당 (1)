#include <string>
#include <vector>
#include <algorithm>

using namespace std;

vector<int> solution(int k, vector<int> score) {
    vector<int> answer;
    vector<int> n;

    for(int i = 0; i < score.size(); i++){
        n.push_back(score[i]);
        sort(n.begin(), n.end(), greater<>());

        if(n.size() > k){
            n.erase(n.begin()+k, n.end());
        }

        answer.push_back(n[n.size()-1]);
    }

    return answer;
}
