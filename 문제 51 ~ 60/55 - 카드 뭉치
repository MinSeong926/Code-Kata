#include <string>
#include <vector>

using namespace std;

string solution(vector<string> cards1, vector<string> cards2, vector<string> goal) {
    int a = 0;
    int b = 0;

    // cards1, cards2 배열과 goal 배열의 순서가 일치하면 Yes, 아니면 No를 출력
    for(int i = 0; i < goal.size(); i++){
        if(cards1[a] == goal[i]){
            a++;
        }
        else if(cards2[b] == goal[i]){
            b++;
        }
        else{
            return "No";
        }
    }
    return "Yes";
}
