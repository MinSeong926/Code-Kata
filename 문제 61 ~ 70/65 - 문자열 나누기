#include <string>
#include <vector>

using namespace std;

int solution(string s) {
    int answer = 0;
    char x = ' ';
    int same = 0;
    int diff = 0;

    for(int i = 0; i < s.length(); i++){
        if(same == diff){
            answer++;
            x = s[i];
            same = 0;
            diff = 0;
        }

        if(s[i] == x){
            same++;
        }
        else{
            diff++;
        }
    }

    return answer;
}
