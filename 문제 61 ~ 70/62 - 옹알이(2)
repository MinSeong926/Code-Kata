#include <string>
#include <vector>

using namespace std;

int solution(vector<string> babbling) {
    int answer = 0;

    string foo[4] = {"aya", "ye", "woo", "ma"};
    int preIndex = -1; // 연속 발음 X

    for(int i = 0; i < babbling.size(); ++i)
    {
        auto word = babbling[i];

        for(int j = 0; j < 4; ++j)
        {
            if(word.substr(0, foo[j].size()) == foo[j] && preIndex != j)
            {
                word.erase(0, foo[j].size());

                preIndex = j; 
                j = -1;
            }
        }

        if(word.size() == 0) ++answer;
        preIndex = -1; 
    }

    return answer;
}
